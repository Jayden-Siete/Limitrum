{
  "name": "limitrum",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.23.0",
  "scripts": {
    "dev": "turbo run dev --parallel --filter=@limitrum/web",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test:unit": "pnpm --filter @limitrum/tests test:unit",
    "db:migrate": "pnpm --filter @limitrum/db migrate",
    "db:seed": "pnpm --filter @limitrum/db seed",
    "hosting:prepare": "node scripts/prepare-hosting.mjs",
    "ci": "pnpm db:migrate && pnpm db:seed && pnpm typecheck && pnpm test:unit && pnpm build",
    "format": "turbo run format"
  },
  "devDependencies": {
    "turbo": "latest",
    "typescript": "latest"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ],
    "overrides": {
      "drizzle-orm": "0.45.1"
    }
  }
}

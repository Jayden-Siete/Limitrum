{
  "name": "@limitrum/cli",
  "version": "0.1.0",
  "private": false,
  "license": "MIT",
  "description": "Command-line simulator and local policy tools for Limitrum.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Jayden-Siete/Limitrum.git",
    "directory": "apps/cli"
  },
  "homepage": "https://limitrum.com",
  "bugs": {
    "url": "https://github.com/Jayden-Siete/Limitrum/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "limitrum": "dist/index.js"
  },
  "scripts": {
    "predev": "pnpm --filter @limitrum/db build && pnpm --filter @limitrum/sdk build",
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "echo \"No lint configured for @limitrum/cli\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@limitrum/db": "workspace:^0.1.0",
    "@limitrum/sdk": "workspace:^0.1.0",
    "commander": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}

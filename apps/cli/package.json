    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@limitrum/sdk": "workspace:*",
    "commander": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}

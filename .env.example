# ─────────────────────────────────────────────────────────────────────────────
# Limitrum — Environment Variables Example
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Local SQLite path (default: file:limitrum.sqlite)
DATABASE_URL=file:limitrum.sqlite

# ── API Server ────────────────────────────────────────────────────────────────
# Port the Hono API server listens on (default: 8000)
PORT=8000

# Node environment: development | production | test
NODE_ENV=development

# ── Authentication ────────────────────────────────────────────────────────────
# Master API key — bypasses DB key lookup (for local dev / CI only)
# Generate with: openssl rand -hex 32
LIMITRUM_MASTER_KEY=

# ── SDK ───────────────────────────────────────────────────────────────────────
# Override the API base URL used by LimitrumGuard in HTTP mode
# Defaults to http://localhost:8000 in development, https://api.limitrum.cloud in production
LIMITRUM_API_URL=http://localhost:8000

# ── Web (Next.js) ─────────────────────────────────────────────────────────────
# Public API URL exposed to the browser (used by the interactive sandbox)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── MCP Server ────────────────────────────────────────────────────────────────
# Port for the SSE transport (default: 8001)
MCP_SSE_PORT=8001

# ── OpenAI (examples only) ────────────────────────────────────────────────────
# Only required for running apps/examples/yolo-agent with real API calls
OPENAI_API_KEY=

# ── Anthropic (examples only) ─────────────────────────────────────────────────
# Only required for running apps/examples with Anthropic models
ANTHROPIC_API_KEY=

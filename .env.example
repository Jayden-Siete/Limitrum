# ─────────────────────────────────────────────
# Limitrum — Environment Variables Example
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# ── Database ──────────────────────────────────
# Local SQLite (default for development — no setup needed)
# LIMITRUM_DB_PATH=./limitrum.sqlite

# Remote LibSQL / Turso (required for production)
# DATABASE_URL=libsql://<db-name>.turso.io
# DATABASE_AUTH_TOKEN=<your-turso-auth-token>

# ── API Server ────────────────────────────────
# Port for the Hono API server (default: 8000 dev, 8080 prod)
PORT=8000

# Node environment
NODE_ENV=development

# ── SDK ───────────────────────────────────────
# URL of the Limitrum Policy Kernel API
# Leave empty to use local DB mode (default for development)
# Set to your deployed API URL for HTTP client mode
LIMITRUM_API_URL=http://localhost:8000

# Master API key for the Limitrum API (generate with: openssl rand -hex 32)
LIMITRUM_MASTER_API_KEY=

# ── Web App ───────────────────────────────────
# Public API URL used by the Next.js frontend
NEXT_PUBLIC_LIMITRUM_API_URL=http://localhost:8000

# ── MCP Server ────────────────────────────────
# Transport mode: stdio (default) | sse
MCP_TRANSPORT=stdio

# Port for SSE transport (default: 8788)
# PORT=8788

# Limitrum local development

# Local SQLite/libSQL database file used by the open-source core.
DATABASE_URL=./limitrum.sqlite

# Optional provider keys for adapting real agent tool calls.
# The examples in this repository can run without paid model usage.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: point the SDK at a Limitrum-compatible HTTP endpoint.
# For local gateway testing, run:
# MCP_TRANSPORT=sse pnpm --filter @limitrum/mcp-server dev:sse
# LIMITRUM_API_URL=http://localhost:8788
# LIMITRUM_API_URL=
# LIMITRUM_API_KEY=

# Optional: require API-key auth on the local HTTP gateway.
# LIMITRUM_GATEWAY_API_KEY=

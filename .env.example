# Limitrum Environment Variables

# API
LIMITRUM_API_URL=http://localhost:8000
LIMITRUM_API_KEY=lmt_demo_c6e6149d7aca04bb53202b0dd435acef
LIMITRUM_MASTER_API_KEY=replace-with-at-least-32-random-characters
LIMITRUM_VERIFY_INTENT_PUBLIC=true
CORS_ORIGIN=http://localhost:3000

# Production hardening:
# - set LIMITRUM_VERIFY_INTENT_PUBLIC=false or leave it unset
# - set CORS_ORIGIN to your trusted frontend origin(s), comma-separated
# - set NODE_ENV=production only with a durable DATABASE_URL

# Database (LibSQL - optional for remote)
DATABASE_URL=libsql://your-project.turso.io
DATABASE_AUTH_TOKEN=your-read-write-token

# OpenAI/Anthropic keys (for examples)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Logging level
LOG_LEVEL=info

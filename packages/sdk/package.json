{
  "name": "@limitrum/sdk",
  "version": "0.1.0",
  "private": false,
  "license": "MIT",
  "description": "Policy kernel SDK for verifying autonomous AI agent actions before execution.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Jayden-Siete/Limitrum.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://limitrum.com",
  "bugs": {
    "url": "https://github.com/Jayden-Siete/Limitrum/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./adapters/openai": {
      "types": "./dist/adapters/openai.d.ts",
      "import": "./dist/adapters/openai.js",
      "default": "./dist/adapters/openai.js"
    },
    "./adapters/anthropic": {
      "types": "./dist/adapters/anthropic.d.ts",
      "import": "./dist/adapters/anthropic.js",
      "default": "./dist/adapters/anthropic.js"
    },
    "./adapters/langchain": {
      "types": "./dist/adapters/langchain.d.ts",
      "import": "./dist/adapters/langchain.js",
      "default": "./dist/adapters/langchain.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "echo \"No lint configured for @limitrum/sdk\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@limitrum/db": "workspace:^0.1.0",
    "drizzle-orm": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}

{
  "name": "@limitrum/db",
  "version": "0.1.1",
  "private": false,
  "license": "MIT",
  "description": "Local SQLite/libSQL policy and audit store for Limitrum.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Jayden-Siete/Limitrum.git",
    "directory": "packages/db"
  },
  "homepage": "https://limitrum.com",
  "bugs": {
    "url": "https://github.com/Jayden-Siete/Limitrum/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "migrate": "tsx src/migrate.ts",
    "seed": "tsx src/seed.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "echo \"No lint configured for @limitrum/db\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@libsql/client": "latest",
    "drizzle-orm": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}
